<script>
(function() {
  var track = document.getElementById('testimonialsTrack');
  var counter = document.getElementById('testimonialsCounter');
  if (!track || !counter) return;

  var items = track.querySelectorAll('.testimonial');
  var current = 0;
  var perPage = window.innerWidth <= 900 ? 1 : window.innerWidth <= 1100 ? 2 : 3;
  var total = Math.ceil(items.length / perPage);

  function update() {
    perPage = window.innerWidth <= 900 ? 1 : window.innerWidth <= 1100 ? 2 : 3;
    total = Math.ceil(items.length / perPage);
    if (current >= total) current = total - 1;
    var itemWidth = (items[0] as HTMLElement).offsetWidth + 24;
    (track as HTMLElement).style.transform = 'translateX(-' + (current * perPage * itemWidth) + 'px)';
    counter.textContent = (current + 1) + ' / ' + total;
  }

  document.getElementById('testimonialsNext')?.addEventListener('click', function() {
    current = (current + 1) % total;
    update();
  });
  document.getElementById('testimonialsPrev')?.addEventListener('click', function() {
    current = (current - 1 + total) % total;
    update();
  });

  window.addEventListener('resize', update);
  update();

  document.getElementById('newsletterForm')?.addEventListener('submit', function(e) {
    e.preventDefault();
    (this as HTMLElement).style.display = 'none';
    var s = document.getElementById('newsletterSuccess');
    if (s) s.style.display = 'block';
  });
})();
</script>
