---
export interface Props {
  lang?: 'de' | 'en';
}
const { lang = 'de' } = Astro.props;

const testimonials = [
  {
    quote: lang === 'de'
      ? 'Ich bin fassungslos, wie viele kraftvolle Inhalte Du zu einem so günstigen Preis anbietest. Ich habe noch nicht mal ein Bruchteil gesehen.'
      : "I'm blown away by how much powerful content you offer at such a low price. I haven't even reached the Reisas yet — still integrating the video practices. Dada, your work is a true gift.",
    author: 'Deborah, 27',
  },
  {
    quote: lang === 'de'
      ? 'Nach der letzten Community Reisa bin ich wie neugeboren aufgewacht. Danke!'
      : 'After the last Community Reisa, I woke up feeling completely renewed — like I had been reborn. Thank you, Dada.',
    author: 'Manuela, 40',
  },
  {
    quote: lang === 'de'
      ? 'Die Reisa war unglaublich schön und heilend. Mein ganzer Körper hat gekribbelt, ich fühlte mich getragen. Am nächsten Morgen: voller Energie. Tausend Dank!'
      : 'The Reisa was incredibly healing. My whole body tingled, I felt held and supported, and I woke up filled with fresh energy. Thank you, thank you, thank you!',
    author: 'Deborah, 28',
  },
  {
    quote: lang === 'de'
      ? 'Die Reisa hat mir gezeigt, wie ich für mich einstehen kann – ohne Vorwurf und Groll. Ich fühle mich gestärkt, den nächsten Schritt zu gehen. Danke für Deine liebevolle Begleitung.'
      : 'Your Reisa helped me see how to stand up for myself without blame or resentment. I feel empowered to move forward. Thank you for your loving guidance.',
    author: 'Esther, 57',
  },
];
---

<section class="section-pad bg-dc-black overflow-hidden">
  <div class="max-w-screen-xl mx-auto">
    <p class="label-tag text-dc-light mb-12 text-center opacity-60">
      {lang === 'de' ? 'Stimmen der Klientinnen' : 'Client Voices'}
    </p>

    <!-- Testimonial grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map(t => (
        <blockquote class="p-6 border border-dc-white/10 flex flex-col gap-4">
          <p class="text-dc-light font-syne text-base leading-relaxed opacity-90">
            "{t.quote}"
          </p>
          <footer class="text-xs font-syne-mono text-dc-light opacity-40 uppercase tracking-widest mt-auto">
            — {t.author}
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
