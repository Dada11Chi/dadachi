---
export interface Props {
  lang?: 'de' | 'en';
  currentPath?: string;
}
const { lang = 'de', currentPath = '/' } = Astro.props;
const altLang = lang === 'de' ? 'en' : 'de';
const altPath = currentPath.replace(`/${lang}/`, `/${altLang}/`);

const R2 = 'https://pub-ba018632258942529034e3ab490a6167.r2.dev';
---

<!-- ANNOUNCEMENT BAR -->
<div class="announcement-bar" id="announcementBar">
  🎁 <a href="https://tally.so/r/w4WBJA" target="_blank" rel="noopener">Gift Certificates available here</a>
  &nbsp;|&nbsp;
  🎁 <a href="https://tally.so/r/w4WBJA" target="_blank" rel="noopener">Hier gibt's Geschenkgutscheine</a>
