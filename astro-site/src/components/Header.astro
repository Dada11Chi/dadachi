</div>

<!-- HEADER -->
<header class="site-header">
  <div class="header-inner">
    <a href={`/${lang}/`} class="site-logo">
      <img loading="eager" src={`${R2}/adbb76e3-8361-4f10-82ea-3e5d7da38d94_Logo_Dada_Chi-2%20%3F%20format%3D1500w.png`} alt="DADA CHI" height="46" />
